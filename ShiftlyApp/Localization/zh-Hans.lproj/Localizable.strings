"Name (optional)" = "名称（可选）";
"Import from a holidays calendar" = "从节假日日历导入";
"Import Holidays" = "导入节假日";
"Upcoming Holidays" = "即将到来的假期";
"Remove holiday" = "删除假期";
"Holiday added." = "假期已添加。";
"Holiday removed." = "假期已删除。";
"Holiday save failed: %@" = "假期保存失败：%@";
"This holiday range already exists." = "该假期区间已存在。";
"Imported %lld holidays." = "已导入 %lld 个节假日。";
"Holiday import failed." = "节假日导入失败。";

